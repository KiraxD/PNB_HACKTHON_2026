# QSecure Radar — Environment Configuration
# SECURITY: Never commit actual credentials. Use this template to configure your environment.

# Supabase Configuration (get from https://app.supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# IMPORTANT: Load these in your build process or runtime environment
# For Vite: Update vite.config.ts to load these
# For Supabase Functions: These are automatically available via Deno.env.get()
# For Local Development: Use `supabase start` which automatically loads .env.local

# Feature Flags (optional)
VITE_ENABLE_ANALYTICS=true
VITE_API_TIMEOUT_MS=30000
VITE_MAX_SCAN_TARGETS=1000
