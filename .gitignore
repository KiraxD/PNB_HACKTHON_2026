# QSecure Radar — .gitignore

# Secrets (never commit these)
.env
.env.local
.env.*.local

# Node
node_modules/
package-lock.json
npm-debug.log*

# Python
__pycache__/
*.pyc
.venv/
*.py

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp
*.swo

# Logs and temp
*.log
.tmp/
tmp/
err.txt

# PDFs & large binaries
*.pdf
*.pptx
*.ppt

# Dev/cleanup scripts (not for prod)
clear-database.js
clear_database.py
load-seed.js
seed-database.js
generate_ppt.py

# Agent skills (local dev only)
.agents/

# Supabase temp state
supabase/.temp/
